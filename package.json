{
  "name": "melisa-bebe-erp-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "desktop": "node scripts/start-electron.cjs",
    "start": "npm run desktop",
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "electron:dev": "npm run desktop",
    "electron:rebuild": "node node_modules/electron-builder/cli.js install-app-deps",
    "kill:dev": "node scripts/kill-dev-processes.cjs",
    "build": "vite build",
    "electron:build": "npm run build -- --base ./ && electron-builder",
    "preview": "vite preview --host 127.0.0.1",
    "vega:readonly-stock-smoke": "node scripts/vega-readonly-stock-smoke-test.mjs",
    "vega:readonly-connection-ping": "node scripts/vega-readonly-connection-ping.mjs"
  },
  "build": {
    "appId": "com.melisabebe.erp",
    "productName": "Melisa Bebe ERP",
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "directories": {
      "buildResources": "buildResources"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "better-sqlite3": "^12.9.0",
    "lucide-react": "^0.561.0",
    "mssql": "^12.5.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  }
}
